
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to get the user's app data from the 'users' collection
    function getAppUser(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    // Helper function to check if the requesting user is an admin
    function isAdmin() {
      return isAuthenticated() && getAppUser(request.auth.uid).role == 'admin';
    }
    
    // Helper function to check if the requesting user is approved
    function isApproved() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getAppUser(request.auth.uid).isApproved == true;
    }

    // USERS COLLECTION
    match /users/{userId} {
      // READ: 
      // - An admin can read any user's profile.
      // - A non-admin user can only read their own profile.
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);

      // CREATE:
      // A user can create their own document upon signup
      allow create: if isAuthenticated() && request.auth.uid == userId
                      && request.resource.data.isApproved == false
                      && request.resource.data.role == 'user'
                      && request.resource.data.keys().hasOnly(['displayName', 'email', 'isApproved', 'role', 'createdAt']);

      // UPDATE:
      // - An admin can update anyone's `isApproved` or `role`.
      // - A user can only update their own settings.
      allow update: if isAdmin() 
                    || (isAuthenticated() && request.auth.uid == userId && request.resource.data.keys().hasAny(['displayName', 'colorSettings', 'fontSize']));
      
      // DELETE: No one should delete user documents.
      allow delete: if false;
    }
    
    // SETLISTS COLLECTION
    match /setlists/{setlistId} {
      // Permite leitura se for aprovado OU se for público (mesmo pendente de aprovação mas logado)
      allow read: if isApproved() || (isAuthenticated() && resource.data.isPublic == true);
      allow write: if isApproved();
    }

    // OTHER COLLECTIONS
    match /{collection}/{docId} {
      // Qualquer usuário aprovado pode acessar outras coleções (músicas, artistas, etc)
      allow read, write: if isApproved() && collection != 'users' && collection != 'setlists';
    }
  }
}
