rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Função central de autenticação
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verificação de admin ultra-direta para evitar falhas de avaliação
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // USERS: Regras para usuários
    match /users/{userId} {
      // Leitura permitida para qualquer autenticado (precisamos listar para gerenciar)
      allow read: if isAuthenticated();
      
      // Criação permitida apenas para o próprio UID no signup
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Update permitido para o próprio usuário ou admins
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Delete permitido APENAS para admins
      // Usamos a lógica direta aqui para máxima segurança e compatibilidade
      allow delete: if request.auth != null && 
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // SETTINGS: Configurações globais
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // MÚSICAS E METADADOS
    match /songs/{docId} { 
      allow read: if isAuthenticated(); 
      allow write: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true); 
    }
    match /categories/{docId} { allow read: if isAuthenticated(); allow write: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true); }
    match /genres/{docId} { allow read: if isAuthenticated(); allow write: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true); }
    match /artists/{docId} { allow read: if isAuthenticated(); allow write: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true); }

    // REPERTÓRIOS
    match /setlists/{setlistId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}