rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper central de autenticação
    function isAuthenticated() {
      return request.auth != null;
    }

    // USERS: Regras para a coleção de usuários
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Atualização permitida para o próprio usuário ou admins
      allow update: if isAuthenticated() && (
        request.auth.uid == userId || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      
      // EXCLUSÃO: Regra direta para evitar falhas de contexto
      allow delete: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // SETTINGS: Configurações globais
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // SETLISTS: Repertórios (Regras básicas de acesso)
    match /setlists/{setlistId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // CATCH-ALL: Outras coleções (músicas, categorias, etc)
    match /{collection}/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true
      );
    }
  }
}