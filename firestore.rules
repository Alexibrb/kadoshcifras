rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to get the user's app data from the 'users' collection
    function getAppUser(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    // Helper function to check if the requesting user is an admin
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getAppUser(request.auth.uid).role == 'admin';
    }
    
    // Helper function to check if the requesting user is approved
    function isApproved() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getAppUser(request.auth.uid).isApproved == true;
    }

    // USERS COLLECTION
    match /users/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);

      allow create: if isAuthenticated() && request.auth.uid == userId
                      && request.resource.data.isApproved == false
                      && request.resource.data.role == 'user';

      allow update: if isAdmin() 
                    || (isAuthenticated() && request.auth.uid == userId);
      
      allow delete: if false;
    }
    
    // SETTINGS COLLECTION
    match /settings/{settingId} {
      // Permite leitura pública (necessário para ver o WhatsApp antes da aprovação)
      allow read: if true;
      // Permite qualquer escrita (create/update) apenas para admins
      allow write: if isAdmin();
    }
    
    // SETLISTS COLLECTION
    match /setlists/{setlistId} {
      allow read: if isAdmin() 
                  || isApproved() 
                  || (isAuthenticated() && (resource.data.isPublic == true || resource.data.isVisible == true))
                  || (isAuthenticated() && resource.data.creatorId == request.auth.uid);
      
      allow write: if isAdmin() 
                   || isApproved()
                   || (isAuthenticated() && (request.resource.data.creatorId == request.auth.uid || resource.data.creatorId == request.auth.uid));
    }

    // SONGS COLLECTION
    match /songs/{songId} {
      allow read: if isAuthenticated();
      allow write: if isApproved() || isAdmin();
    }

    // OTHER COLLECTIONS
    match /{collection}/{docId} {
      allow read: if isAuthenticated();
      allow write: if isApproved() || isAdmin();
    }
  }
}
