
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Função central de autenticação
    function isAuthenticated() {
      return request.auth != null;
    }

    // Função para buscar dados do usuário atual
    function getAppUser(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    // Função de verificação de admin
    function isAdmin() {
      return isAuthenticated() && getAppUser(request.auth.uid).role == 'admin';
    }

    // USERS: Regras para usuários
    match /users/{userId} {
      // Separamos list e get para maior clareza e segurança
      allow list: if isAdmin();
      allow get: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Permitir exclusão para administradores
      allow delete: if isAdmin();
    }
    
    // SETTINGS: Configurações globais
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // MÚSICAS E METADADOS
    match /songs/{docId} { allow read: if isAuthenticated(); allow write: if isAuthenticated() && (isAdmin() || getAppUser(request.auth.uid).isApproved == true); }
    match /categories/{docId} { allow read: if isAuthenticated(); allow write: if isAuthenticated() && (isAdmin() || getAppUser(request.auth.uid).isApproved == true); }
    match /genres/{docId} { allow read: if isAuthenticated(); allow write: if isAuthenticated() && (isAdmin() || getAppUser(request.auth.uid).isApproved == true); }
    match /artists/{docId} { allow read: if isAuthenticated(); allow write: if isAuthenticated() && (isAdmin() || getAppUser(request.auth.uid).isApproved == true); }

    // REPERTÓRIOS
    match /setlists/{setlistId} {
      // Regra de Leitura Segura:
      // 1. Criador e Admin sempre podem ler.
      // 2. Outros podem ler se isVisible for true E (se houver eventDate, ela não tiver passado).
      allow read: if isAuthenticated() && (
        resource.data.creatorId == request.auth.uid || 
        isAdmin() || 
        (resource.data.isVisible == true && (resource.data.eventDate == null || resource.data.eventDate >= request.time))
      );
      
      // Escrita: Apenas usuários autenticados (a lógica de quem pode editar o que é tratada via UI e visibilidade)
      allow write: if isAuthenticated();
    }
  }
}
