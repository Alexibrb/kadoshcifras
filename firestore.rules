rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Verifica se o usuário está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Verifica se o usuário logado é um administrador
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper: Verifica se o usuário logado está aprovado (ou é admin)
    function isApproved() {
      return isAuthenticated() && 
             (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true);
    }

    // USERS: Regras específicas para a coleção de usuários
    match /users/{userId} {
      // Qualquer admin pode ler todos; usuários logados leem apenas o próprio
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      // Criação permitida no momento do cadastro (auto-registro)
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Atualização permitida para o próprio usuário ou admins
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      // EXCLUSÃO: Apenas administradores podem excluir usuários
      allow delete: if isAdmin();
    }
    
    // SETTINGS: Configurações globais do sistema
    match /settings/{settingId} {
      allow read: if true; // Aberto para leitura (necessário para tela de pendência)
      allow write: if isAdmin(); // Apenas admin altera configurações
    }
    
    // SETLISTS: Repertórios
    match /setlists/{setlistId} {
      allow read: if isAdmin() 
                  || isApproved() 
                  || (isAuthenticated() && (resource.data.isPublic == true || resource.data.isVisible == true))
                  || (isAuthenticated() && resource.data.creatorId == request.auth.uid);
      
      allow write: if isAdmin() 
                   || isApproved()
                   || (isAuthenticated() && (request.resource.data.creatorId == request.auth.uid || resource.data.creatorId == request.auth.uid));
    }

    // SONGS: Biblioteca de músicas
    match /songs/{songId} {
      allow read: if isAuthenticated();
      allow write: if isApproved() || isAdmin();
    }

    // METADATA: Artistas, Gêneros, Categorias
    match /categories/{docId} { allow read: if isAuthenticated(); allow write: if isApproved() || isAdmin(); }
    match /genres/{docId} { allow read: if isAuthenticated(); allow write: if isApproved() || isAdmin(); }
    match /artists/{docId} { allow read: if isAuthenticated(); allow write: if isApproved() || isAdmin(); }

    // CATCH-ALL: Regra geral para outras coleções
    match /{collection}/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isApproved();
    }
  }
}