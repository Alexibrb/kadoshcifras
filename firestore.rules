rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the requesting user is an admin
    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if the requesting user is approved
    function isApproved() {
      return isAuthenticated() && 
             (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true);
    }

    // USERS COLLECTION
    match /users/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }
    
    // SETTINGS COLLECTION
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // SETLISTS COLLECTION
    match /setlists/{setlistId} {
      allow read: if isAdmin() 
                  || isApproved() 
                  || (isAuthenticated() && (resource.data.isPublic == true || resource.data.isVisible == true))
                  || (isAuthenticated() && resource.data.creatorId == request.auth.uid);
      
      allow write: if isAdmin() 
                   || isApproved()
                   || (isAuthenticated() && (request.resource.data.creatorId == request.auth.uid || resource.data.creatorId == request.auth.uid));
    }

    // SONGS COLLECTION
    match /songs/{songId} {
      allow read: if isAuthenticated();
      allow write: if isApproved() || isAdmin();
    }

    // METADATA COLLECTIONS
    match /categories/{docId} { allow read: if isAuthenticated(); allow write: if isApproved() || isAdmin(); }
    match /genres/{docId} { allow read: if isAuthenticated(); allow write: if isApproved() || isAdmin(); }
    match /artists/{docId} { allow read: if isAuthenticated(); allow write: if isApproved() || isAdmin(); }

    // OTHER COLLECTIONS
    match /{collection}/{docId} {
      allow read: if isAuthenticated();
      allow write: if isApproved() || isAdmin();
    }
  }
}