rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Funções auxiliares básicas
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isApproved() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true;
    }

    // USERS: Regras específicas para a coleção de usuários
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Permitir atualização se for o próprio usuário ou se for admin
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // EXCLUSÃO: Apenas administradores podem excluir
      allow delete: if isAdmin();
    }
    
    // SETTINGS: Configurações globais
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // MÚSICAS E METADADOS
    match /songs/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isApproved(); }
    match /categories/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isApproved(); }
    match /genres/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isApproved(); }
    match /artists/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isApproved(); }

    // REPERTÓRIOS
    match /setlists/{setlistId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}