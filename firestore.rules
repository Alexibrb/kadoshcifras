rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Função auxiliar básica
    function isAuthenticated() {
      return request.auth != null;
    }

    // USERS: Regras específicas para a coleção de usuários
    match /users/{userId} {
      // Regra de exclusão: Permite se o usuário logado for admin no Firestore
      allow delete: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      
      // Leitura permitida para qualquer autenticado
      allow read: if isAuthenticated();
      
      // Criação permitida para o próprio usuário
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Atualização permitida para o próprio ou admin
      allow update: if isAuthenticated() && (
        request.auth.uid == userId || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    
    // SETTINGS: Configurações globais
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // MÚSICAS E METADADOS
    match /songs/{docId} { 
      allow read: if isAuthenticated(); 
      allow write: if isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true
      ); 
    }
    match /categories/{docId} { allow read: if isAuthenticated(); allow write: if isAuthenticated() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true); }
    match /genres/{docId} { allow read: if isAuthenticated(); allow write: if isAuthenticated() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true); }
    match /artists/{docId} { allow read: if isAuthenticated(); allow write: if isAuthenticated() && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true); }

    // REPERTÓRIOS
    match /setlists/{setlistId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}