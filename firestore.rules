rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Função auxiliar para verificar se o usuário é admin de forma robusta
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // USERS: Coleção crítica de usuários
    match /users/{userId} {
      // Leitura: Qualquer logado pode ler (para listar no painel)
      allow read: if isAuthenticated();
      
      // Criação: O próprio usuário cria seu documento no signup
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Atualização: O próprio ou um admin
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // EXCLUSÃO: Apenas Admin pode excluir usuários
      // Nota: Esta regra é absoluta e não depende do userId do alvo
      allow delete: if isAdmin();
    }
    
    // SETTINGS: Configurações globais (apenas admin escreve)
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // MÚSICAS E METADADOS
    match /songs/{docId} { 
      allow read: if isAuthenticated(); 
      allow write: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true); 
    }
    match /categories/{docId} { allow read: if isAuthenticated(); allow write: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true); }
    match /genres/{docId} { allow read: if isAuthenticated(); allow write: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true); }
    match /artists/{docId} { allow read: if isAuthenticated(); allow write: if isAuthenticated() && (isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true); }

    // REPERTÓRIOS
    match /setlists/{setlistId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}