rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Verifica se o usuário está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Verifica se o usuário logado é um administrador
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper: Verifica se o usuário logado está aprovado ou é admin
    function isApproved() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true
      );
    }

    // USERS: Regras para a coleção de usuários
    match /users/{userId} {
      // Leitura: Admin lê todos, usuário lê o próprio
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Criação: Auto-registro
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Atualização: Admin ou o próprio usuário
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // EXCLUSÃO: Apenas administradores podem deletar usuários
      allow delete: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // SETTINGS: Configurações globais
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // SETLISTS: Repertórios
    match /setlists/{setlistId} {
      allow read: if isAuthenticated() && (
        isAdmin() || 
        isApproved() || 
        resource.data.isPublic == true || 
        resource.data.isVisible == true || 
        resource.data.creatorId == request.auth.uid
      );
      
      allow write: if isAuthenticated() && (
        isAdmin() || 
        isApproved() || 
        (exists(resource) && resource.data.creatorId == request.auth.uid) ||
        (!exists(resource) && request.resource.data.creatorId == request.auth.uid)
      );
    }

    // CATCH-ALL: Regra geral para outras coleções (Songs, Categorias, Artistas, Gêneros)
    match /{collection}/{docId} {
      allow read: if isAuthenticated();
      allow write: if isApproved();
    }
  }
}